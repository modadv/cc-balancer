{
  "name": "cc-balancer",
  "version": "0.2.0",
  "description": "Config-driven Claude API gateway with multi-upstream failover and cooldown handling.",
  "type": "module",
  "bin": {
    "cc-balancer": "./dist/src/cli/index.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist/src",
    "README.md",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli/index.ts",
    "start": "tsx src/cli/index.ts start -c examples/config.yaml",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "anthropic",
    "claude",
    "gateway",
    "proxy",
    "balancer"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "js-yaml": "^4.1.0",
    "pino": "^10.1.0",
    "undici": "^7.16.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
